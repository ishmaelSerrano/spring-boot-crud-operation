def VERSION = "0.0.1"
def DIST_ARCHIVE = "dist.0.0.1"
def S3_BUCKET = 'spring-boot-angular'

pipeline {
    agent any
    tools { nodejs "Angular Project" }

    stages {
        stage('NPM Install') {
            steps {
                script {
                    notifyBitbucket(buildStatus: 'INPROGRESS')
                }
                sh 'npm install --verbose -d'
            }
        }

        stage('Build') {
            steps {
                sh 'npm run build'
            }
        }
        stage('Archive') {
            steps {
              sh "cd frontend/dist/angular-frontend-books && zip -r ../app.zip . && cd .."
              archiveArtifacts artifacts: "app.zip", fingerprint: true
            }
        }
        stage('Deploy') {
            steps {
                sh "aws s3 cp app.zip s3://spring-boot-angular/app.zip --profile=default"
                sh "aws deploy create-deployment --application-name Angular --deployment-config-name CodeDeployDefault.AllAtOnce --deployment-group-name angular-deployment-group --s3-location bucket=spring-boot-angular,bundleType=zip,key=app.zip"
            }
        }
    }

    post {
        always {
            script {
                currentBuild.result = currentBuild.result ?: 'SUCCESS'
                notifyBitbucket()

                if (currentBuild.result == 'SUCCESS') {
                  echo 'notify slack'
                } else {
                  echo 'notify slack'
                }
            }
        }
    }
}
