pipeline {
    agent any

    stages {


        stage('Deploy') {
            environment {
                // Set environment variables for AWS ECS deployment
                AWS_REGION = 'us-east-1'
                ECS_CLUSTER = 'deployment-springboot-angular-cluster'
                ECS_SERVICE = 'springboot-angular-service'
                IMAGE_TAG = sh(returnStdout: true, script: 'echo $BUILD_NUMBER').trim()
            }

            steps {
                // Authenticate Docker with AWS ECR
                withAWS(credentials: 'aws-credentials', region: env.AWS_REGION, env.AWS_ACCESS_KEY, env.AWS_SECRET_KEY) {
                    sh 'aws ecr get-login-password --region env.AWS_REGION | docker login --username AWS --password-stdin env.AWS_ACCOUNT_ID.dkr.ecr.env.AWS_REGION.amazonaws.com'
                }

                // Build Docker image
                sh 'docker build -t spring-boot-crud-operation:0.0.1 .'

                // Tag Docker image
                sh 'docker tag spring-boot-crud-operation:0.0.1 $AWS_ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com/spring-boot-crud-operation:0.0.1'

                // Push Docker image to AWS ECR
                sh 'docker push $AWS_ACCOUNT_ID.dkr.ecr.$AWS_REGION.amazonaws.com/spring-boot-crud-operation:0.0.1'

                // Update AWS ECS service with new task definition
                sh 'ecs deploy $ECS_CLUSTER $ECS_SERVICE --task-definition spring-boot-crud-operation:0.0.1'
            }
        }
    }
}
